class Solution:
    def perfectSum(self, arr, target):
        n = len(arr)
        # dp[j] stores the number of subsets with sum j
        dp = [0] * (target + 1)
        
        # Base case: There is one way to make sum 0 (the empty set)
        dp[0] = 1
        
        # Process each number in the array
        for num in arr:
            # Update the dp table from right to left
            # This ensures each element is used only once per subset
            for j in range(target, num - 1, -1):
                dp[j] = dp[j] + dp[j - num]
                
        return dp[target]
